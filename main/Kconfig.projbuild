menu "HapticHatch"
    config HAPTIC_QUEUE_DEPTH
        int "Haptic receive queue depth"
        default 4
        help
            FreeRTOS queue depth for incoming haptic packets.
            Oldest packets are dropped when full to maintain low latency.

    menu "Signaling Demo"
        config AGORA_APP_ID
            string "Agora App ID"
            default ""
            help
                Agora project App ID from the Agora Console.

        config AGORA_SIGNALING_UID_A
            string "Signaling UID A"
            default "device_a"
            help
                First peer identity (max 64 chars).

        config AGORA_SIGNALING_UID_B
            string "Signaling UID B"
            default "device_b"
            help
                Second peer identity (max 64 chars).

        config AGORA_SIGNALING_TOKEN_A
            string "Signaling token for UID A"
            default ""
            help
                Token issued for UID A. Leave empty to disable token auth.

        config AGORA_SIGNALING_TOKEN_B
            string "Signaling token for UID B"
            default ""
            help
                Token issued for UID B. Leave empty to disable token auth.

        config AGORA_SIGNALING_DEVICE_ID
            string "Device ID for this board (A or B)"
            default "A"
            help
                Identity this build takes at runtime.
                  "A" → login as UID A, send to UID B
                  "B" → login as UID B, send to UID A
                Change to "B" between the two flashes so each board takes a
                different identity; tokens do not need to be regenerated.

        config DEMO_WIFI_SSID
            string "WiFi SSID"
            default ""
            help
                SSID of the 2.4 GHz WiFi network to connect to.

        config DEMO_WIFI_PASSWORD
            string "WiFi password"
            default ""
            help
                Password for the WiFi network. Leave empty for open networks.
    endmenu
endmenu
